{
  "name": "docs",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm styles:build && node --watch --import remix/node-tsx server.ts",
    "start": "pnpm styles:build && node --import remix/node-tsx server.ts",
    "styles:build": "tailwindcss --input app/styles/tailwind.css --output app/assets/tailwind.generated.css",
    "test": "node --import remix/node-tsx --test",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=24.3.0"
  },
  "dependencies": {
    "lucide-static": "catalog:",
    "radcn": "workspace:*",
    "remix": "^3.0.0-beta.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "catalog:",
    "@types/node": "latest",
    "tailwindcss": "catalog:",
    "typescript": "latest"
  }
}
